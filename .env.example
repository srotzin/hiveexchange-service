# HiveExchange Environment Variables
# Copy to .env and fill in values

# Server port
PORT=3010

# PostgreSQL connection string (optional — falls back to in-memory if not set)
DATABASE_URL=postgresql://user:password@host:5432/hiveexchange

# HiveGate DID registry + trust scores
HIVEGATE_URL=https://hivegate.onrender.com

# HiveBank settlement confirmation
HIVEBANK_URL=https://hivebank.onrender.com

# Internal Hive API key (for admin/resolver routes)
HIVE_INTERNAL_KEY=hive_internal_125e04e071e8829be631ea0216dd4a0c9b707975fcecaf8c62c6a2ab43327d46
